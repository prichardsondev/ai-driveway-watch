# Use one local camera URL. Keep the real URL only in .env.
CAMERA_URL=
SOURCE_MODE=sample

MODEL_PATH=models/object_detection_yolox_2022nov_int8.onnx
CONFIDENCE_THRESHOLD=0.40
PERSON_CONFIDENCE_THRESHOLD=0.25
ANIMAL_CONFIDENCE_THRESHOLD=0.35
ANIMAL_ALERTS_ENABLED=true
# Disable duplicate driveway/mailbox/road archives on a wildlife-only Pi.
GENERAL_EVENTS_ENABLED=true
NMS_THRESHOLD=0.50
DETECTION_FPS=5
# Optional MegaDetector V6 pass for camera-trap-trained animal detection.
# Export the model first; see cpp_pi_ncnn/README.md.
WILDLIFE_MODEL_ENABLED=false
WILDLIFE_DETECTION_FPS=1
WILDLIFE_CONFIDENCE_THRESHOLD=0.20
WILDLIFE_PARAM_PATH=wildlife-model/model.ncnn.param
WILDLIFE_MODEL_PATH=wildlife-model/model.ncnn.bin
# Optional second-stage regional classifier. It listens only on localhost and
# receives in-memory crops after MegaDetector finds an animal candidate.
SPECIES_CLASSIFIER_ENABLED=false
SPECIES_CLASSIFIER_REQUIRED=true
SPECIES_CLASSIFIER_PORT=8765
SPECIES_CONFIDENCE_THRESHOLD=0.65
SPECIES_CLASSIFIER_TIMEOUT_SECONDS=8
SPECIES_CACHE_SECONDS=8
# Save locally labeled candidates for field testing without sending alerts.
WILDLIFE_TEST_CAPTURES_ENABLED=false
WILDLIFE_TEST_COOLDOWN_SECONDS=30
WILDLIFE_TEST_SNAPSHOT_RETENTION=200
MANUAL_STORAGE_ROOT=/mnt/driveway-recordings
MANUAL_RECORDING_SECONDS=30
MANUAL_STORAGE_MAX_GB=200
MANUAL_STORAGE_MIN_FREE_GB=10
CLASS_FILTER=person,car,truck,bus,motorcycle,bicycle
INFERENCE_INTERVAL=15
OPENCV_THREADS=4

# Normalized x,y pairs. This defaults to the entire image. Tune from the dashboard.
DRIVEWAY_ZONE=0.0,0.0;1.0,0.0;1.0,1.0;0.0,1.0
DRIVEWAY_LABEL=Driveway arrival
EVENT_COOLDOWN_SECONDS=60
EVENT_CLEAR_SECONDS=5

# Optional road-side mailbox zone. Vehicles must remain nearly still before firing.
MAILBOX_ZONE=
MAILBOX_LABEL=Mailbox stop
MAILBOX_DWELL_SECONDS=2.5
MAILBOX_LOST_SECONDS=1.0
MAILBOX_COOLDOWN_SECONDS=300
MAILBOX_MAX_MOVEMENT=0.035

# Passing traffic archive. Each tracked vehicle is saved once and never alerts.
ROAD_ZONE=
ROAD_LABEL=Road archive
ROAD_TRACK_LOST_SECONDS=0.8
ROAD_TRACK_MATCH_DISTANCE=0.20
ROAD_SNAPSHOT_RETENTION=100000
SNAPSHOTS_ENABLED=true

STREAM_FPS=10
CAPTURE_BUFFER_SIZE=1
RECONNECT_DELAY_SECONDS=2
OUTPUT_DIR=runtime
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Optional text-only phone alerts. Keep the real random topic only in .env.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
